        <mxCell id="bc01_badge" value="CORE DOMAIN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6c8ebf;strokeColor=#6c8ebf;fontStyle=1;fontSize=9;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="930" y="168" width="100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="bc01_content" value="AGREGATS&#xa;&#xa;Tournee (Aggregate Root)&#xa;  - TourneeId, LivreurId, Statut&#xa;  - Date : DateValue (VO)&#xa;  - Colis[] (entites internes)&#xa;  - commandeIds[] : idempotence&#xa;&#xa;Colis (Entity)&#xa;  - ColisId, StatutColis&#xa;  - Adresse : AdresseLivraison (VO)&#xa;  - Preuve : PreuveRef (VO)&#xa;  - MotifEchec (VO, obligatoire si echec)&#xa;&#xa;REGLES METIER&#xa;&#xa;  Offline-first : commandes idempotentes (commandId)&#xa;  Preuve immuable apres capture&#xa;  MotifEchec obligatoire sur echec livraison&#xa;  Tournee demarre uniquement si &gt;= 1 colis&#xa;&#xa;DOMAIN EVENTS EMIS&#xa;&#xa;  TourneeDemarree &#x2192; BC-03&#xa;  LivraisonConfirmee &#x2192; BC-02, BC-03, BC-05&#xa;  EchecLivraisonDeclare &#x2192; BC-03, BC-05&#xa;  TourneeCloturee &#x2192; BC-03, BC-05" style="text;html=1;strokeColor=#6c8ebf;fillColor=#ebf4ff;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="910" y="215" width="540" height="430" as="geometry" />
        </mxCell>

