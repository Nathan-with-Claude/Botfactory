        <mxCell id="bc02_badge" value="SUPPORTING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#82b366;strokeColor=#82b366;fontStyle=1;fontSize=9;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="1590" y="168" width="90" height="20" as="geometry" />
