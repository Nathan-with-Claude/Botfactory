        </mxCell>

        <!-- ============================================================ -->
        <!-- BC-01 ORCHESTRATION DE TOURNEE (Core)                         -->
        <!-- ============================================================ -->
        <mxCell id="bc01_container" value="BC-01 — Orchestration de Tournee" style="swimlane;startSize=45;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=13;" vertex="1" parent="1">
